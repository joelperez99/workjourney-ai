# ============================================================
# WorkJourney AI — Variables de entorno
# Copia este archivo como ".env" y completa los valores.
# ============================================================

# ID de la Google Sheet que funcionará como base de datos.
# Se encuentra en la URL: https://docs.google.com/spreadsheets/d/ESTE_ES_EL_ID/edit
GOOGLE_SHEET_ID=

# Ruta al archivo JSON de la cuenta de servicio de Google Cloud.
# Ver README.md -> "Configuración de Google Sheets" para generarlo.
GOOGLE_SERVICE_ACCOUNT_FILE=config/service_account.json

# Nombre de la aplicación (usado en el título y el login)
APP_NAME=WorkJourney AI

# Clave secreta usada para firmar las cookies de sesión del login
AUTH_COOKIE_KEY=change_this_secret_key
AUTH_COOKIE_NAME=workjourney_auth
AUTH_COOKIE_EXPIRY_DAYS=30

# Zona horaria de la aplicación
APP_TIMEZONE=America/Mexico_City

# Moneda por defecto (símbolo)
DEFAULT_CURRENCY=USD
